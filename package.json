    "db:migrate:status": "prisma migrate status",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:dev": "cross-env SEED_MODE=dev tsx prisma/seed.ts",
    "db:seed:prod": "cross-env SEED_MODE=prod tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "upload:static": "tsx scripts/upload-static-images.ts"
