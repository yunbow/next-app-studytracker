# =============================================================================
# next-app-studytracker 環境変数テンプレート
#
# 使い方:
#   1. このファイルを `.env` にコピー: `cp .env.example .env`
#   2. 必須項目 (# Required と書かれた行) を埋める
#   3. 機能を有効化する任意項目があればまとめてセットする (片欠け禁止)
#
# Source of Truth:
#   - 検証スキーマ: `src/lib/config/env.ts` (Zod)
#   - ローカル手順: `docs/usages/local-setup.md`
#
# Note:
#   - .env はリポジトリにコミットしない (`.gitignore` で除外済)
#   - secret 系は本番で必ず再生成する
# =============================================================================

# -----------------------------------------------------------------------------
# Node.js 環境
# -----------------------------------------------------------------------------
NODE_ENV="development"

# -----------------------------------------------------------------------------
# ログレベル (Optional)
# -----------------------------------------------------------------------------
# Optional — サーバーログの詳細度。開発時は "debug" 推奨。
# 値: fatal | error | warn | info | debug | trace
LOG_LEVEL="info"

# -----------------------------------------------------------------------------
# Database (Prisma)
# -----------------------------------------------------------------------------
# Required
# PostgreSQL 接続文字列。`docker compose up -d` でローカル DB を起動してから設定する。
# 形式: postgresql://user:password@host:port/dbname?schema=public
DATABASE_URL=postgresql://app:app@localhost:54339/app?schema=public

# -----------------------------------------------------------------------------
# Auth.js v5 認証
# Note: studytracker は Auth.js v5 命名 (AUTH_SECRET / AUTH_URL) に完全移行済み。
# -----------------------------------------------------------------------------
# Required
# セッション暗号化キー。32 文字以上必須。
# 生成: openssl rand -base64 48
AUTH_SECRET=""
# Required
# アプリの公開 URL (開発: http://localhost:3000)
AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Google OAuth (Optional) — Auth.js v5 命名
# AUTH_GOOGLE_ID と AUTH_GOOGLE_SECRET は両方セットするか、両方未設定にすること。
# 片方だけ設定すると起動時に "Google OAuth keys must be all-set or all-unset" で失敗する。
# 取得: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# -----------------------------------------------------------------------------
# GitHub OAuth (Optional) — Auth.js v5 命名
# AUTH_GITHUB_ID と AUTH_GITHUB_SECRET は両方セットするか、両方未設定にすること。
# 片方だけ設定すると起動時に "GitHub OAuth keys must be all-set or all-unset" で失敗する。
# 取得: https://github.com/settings/developers
# -----------------------------------------------------------------------------
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# -----------------------------------------------------------------------------
# メール送信 — Auth.js v5 Email Provider (Optional)
# EMAIL_SERVER_HOST / EMAIL_SERVER_USER / EMAIL_SERVER_PASSWORD は 3 つすべてセットするか、すべて未設定にすること。
# Gmail: smtp.gmail.com (ポート 587) / Outlook: smtp-mail.outlook.com (ポート 587)
# -----------------------------------------------------------------------------
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
# Optional — 送信元メールアドレス (例: noreply@example.com)
EMAIL_FROM=""

# -----------------------------------------------------------------------------
# Public 環境変数 (クライアントバンドルに埋め込まれる)
# NEXT_PUBLIC_ プレフィックス付きの値は そのままブラウザに送信される。
# 秘密情報 (API key の write 権限、DB 接続文字列、署名鍵) を絶対に入れないこと。
# -----------------------------------------------------------------------------
# Optional — アプリの公開 URL (OG 画像・sitemap の絶対 URL に使用)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Object Storage — Cloudflare R2 (本番) / MinIO (ローカル開発)
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY / R2_BUCKET_NAME / R2_ENDPOINT は
# 4 つすべてセットするか、すべて未設定にすること。R2_PUBLIC_URL は省略可。
# ローカル: `docker compose up -d` で MinIO を起動後、下記をそのまま使う。
# MinIO コンソール: http://localhost:9001 (minioadmin / minioadmin)
# 本番: Cloudflare R2 の API トークンと公開 URL に差し替える。
# -----------------------------------------------------------------------------
# Cloudflare R2 (本番)
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_ENDPOINT=""
# R2_PUBLIC_URL=""

# MinIO (ローカル開発 — docker compose up -d で起動)
R2_ACCESS_KEY_ID="minioadmin"
R2_SECRET_ACCESS_KEY="minioadmin"
R2_BUCKET_NAME="studytracker"
R2_ENDPOINT="http://localhost:9000"
R2_PUBLIC_URL="http://localhost:9000/studytracker"

# -----------------------------------------------------------------------------
# Stripe — サブスクリプション課金 (Optional)
# STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET / STRIPE_BASIC_PRICE_ID / STRIPE_PREMIUM_PRICE_ID
# は 4 つすべてセットするか、すべて未設定にすること。
#
# ローカル開発: docker compose up -d で stripe-mock が起動し、下記デフォルト値がそのまま使える。
#   stripe-mock は Stripe API の HTTP モックサーバー (ポート 12111)。
#   API 呼び出し (Checkout・Portal) をローカルで動作確認できる。
#   ウェブフックの受信テストには別途 Stripe CLI が必要:
#     stripe listen --forward-to localhost:3000/api/stripe/webhook
#
# 本番: Stripe ダッシュボードの実際の値に差し替える。
#   取得: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------

# stripe-mock (ローカル開発 — docker compose up -d で起動)
STRIPE_SECRET_KEY="sk_test_123"
STRIPE_WEBHOOK_SECRET="whsec_test_local_mock_do_not_use_in_production"
STRIPE_BASIC_PRICE_ID="price_basic"
STRIPE_PREMIUM_PRICE_ID="price_premium"
# stripe-mock の HTTP エンドポイントを指定。未設定時は本番 Stripe API に接続する。
STRIPE_MOCK_HOST="localhost"

# 本番 Stripe (ローカル開発では上記のコメントアウト済み値を使う)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_BASIC_PRICE_ID="price_..."
# STRIPE_PREMIUM_PRICE_ID="price_..."
# STRIPE_MOCK_HOST=  # 本番では未設定にする
